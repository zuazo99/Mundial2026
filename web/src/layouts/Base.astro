---
interface Props {
  title?: string;
}
const { title = "Mundial 2026 — Predictor ML" } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Predicción del Mundial 2026 con Machine Learning" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Flag icons via CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" />
    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body data-active-variant="misterclaude">
    <slot />
  </body>
</html>
