---
// Shows which models agree on a match outcome
interface Props {
  winners: string[]; // [misterclaude winner, gemaldini winner, dav_gpo winner]
  labels?: string[];
}
const { winners, labels = ['MC', 'GEM', 'DAV'] } = Astro.props;
const unique = [...new Set(winners)];
const allAgree = unique.length === 1;
const twoAgree = unique.length === 2;
---
{allAgree ? (
  <span title="Los 3 modelos coinciden" class="inline-flex items-center gap-0.5 text-[10px] font-bold text-[var(--green)] bg-[var(--green)]/10 px-1.5 py-0.5 rounded">
    ✓ 3/3
  </span>
) : twoAgree ? (
  <span title="2 de 3 modelos coinciden" class="inline-flex items-center gap-0.5 text-[10px] font-bold text-[var(--amber)] bg-[var(--amber)]/10 px-1.5 py-0.5 rounded">
    ~ 2/3
  </span>
) : (
  <span title="Todos los modelos discrepan" class="inline-flex items-center gap-0.5 text-[10px] font-bold text-[var(--red)] bg-[var(--red)]/10 px-1.5 py-0.5 rounded">
    ✗ 0/3
  </span>
)}
