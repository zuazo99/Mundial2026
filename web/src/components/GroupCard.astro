---
import Flag from './Flag.astro';
import MatchCard from './MatchCard.astro';
import type { GroupStandings } from '../lib/computeStandings';
import type { XGEntry } from '../data/xg';
import type { MatchResult } from '../data/predictions';
import type { RealResult } from '../data/realResults';
import type { TeamProb } from '../data/probabilities';

interface Props {
  standings: GroupStandings;
  xgJ1: XGEntry[];
  xgJ2: XGEntry[];
  xgJ3: XGEntry[];
  realResults: RealResult[];
  teamProbs?: Record<string, TeamProb>;
}
const { standings, xgJ1, xgJ2, xgJ3, realResults, teamProbs } = Astro.props;

function lookupXG(entries: XGEntry[], team: string) {
  return entries.find(e => e.team === team)?.xg;
}

function lookupReal(m: MatchResult): { r1: number; r2: number } | undefined {
  const found = realResults.find(r =>
    (r.homeTeam === m.team1 && r.awayTeam === m.team2) ||
    (r.homeTeam === m.team2 && r.awayTeam === m.team1)
  );
  if (!found) return undefined;
  if (found.homeTeam === m.team1) return { r1: found.homeGoals, r2: found.awayGoals };
  return { r1: found.awayGoals, r2: found.homeGoals };
}

const posColor = (pos: number) => {
  if (pos <= 2) return 'bg-[var(--green)]/20 border-l-2 border-[var(--green)]';
  if (pos === 3) return 'bg-[var(--amber)]/10 border-l-2 border-[var(--amber)]';
  return '';
};

const jornadas = [
  { label: 'Jornada 1', matches: standings.matchdays[0], xg: xgJ1 },
  { label: 'Jornada 2', matches: standings.matchdays[1], xg: xgJ2 },
  { label: 'Jornada 3', matches: standings.matchdays[2], xg: xgJ3 },
];
---

<div class="rounded-xl border border-[var(--border)] bg-[var(--bg-card)] overflow-hidden">
  <!-- Group header -->
  <div class="bg-[var(--bg-muted)] px-4 py-2 flex items-center gap-2">
    <span class="text-xs font-bold uppercase tracking-widest text-[var(--gold)]">Grupo</span>
    <span class="text-xl font-black">{standings.letter}</span>
  </div>

  <!-- Standings table -->
  <div class="px-4 pt-3 pb-2">
    <table class="w-full text-xs">
      <thead>
        <tr class="text-[var(--text-muted)] uppercase tracking-wide">
          <th class="text-left pb-1 w-full">Equipo</th>
          <th class="text-center pb-1 px-1 w-6">J</th>
          <th class="text-center pb-1 px-1 w-6">G</th>
          <th class="text-center pb-1 px-1 w-6">E</th>
          <th class="text-center pb-1 px-1 w-6">P</th>
          <th class="text-center pb-1 px-1 w-8">GD</th>
          <th class="text-center pb-1 px-1 w-7 font-bold">Pts</th>
          {teamProbs && <th class="text-center pb-1 px-1 w-10 text-[var(--blue)]">Clas%</th>}
        </tr>
      </thead>
      <tbody>
        {standings.teams.map((t) => (
          <tr class={`${posColor(t.pos ?? 4)} rounded`}>
            <td class="py-1 pl-2 flex items-center gap-2">
              <Flag team={t.team} />
              <span class="truncate max-w-[110px]">{t.team}</span>
            </td>
            <td class="text-center text-[var(--text-muted)]">{t.played}</td>
            <td class="text-center">{t.won}</td>
            <td class="text-center">{t.drawn}</td>
            <td class="text-center">{t.lost}</td>
            <td class="text-center text-[var(--text-muted)]">{t.gd > 0 ? `+${t.gd}` : t.gd}</td>
            <td class="text-center font-bold text-[var(--gold)]">{t.pts}</td>
            {teamProbs && (() => {
              const pR32 = teamProbs[t.team]?.pR32 ?? 0;
              const color = pR32 >= 0.7 ? 'text-[var(--green)]' : pR32 >= 0.4 ? 'text-[var(--amber)]' : 'text-[var(--text-muted)]';
              return <td class={`text-center text-[10px] font-semibold ${color}`}>{(pR32 * 100).toFixed(0)}%</td>;
            })()}
          </tr>
        ))}
      </tbody>
    </table>
    <p class="text-[10px] text-[var(--text-muted)] mt-1">
      <span class="inline-block w-2 h-2 rounded-sm bg-[var(--green)]/60 mr-1"></span>Clasifican ·
      <span class="inline-block w-2 h-2 rounded-sm bg-[var(--amber)]/40 ml-1 mr-1"></span>Posible mejor 3º
    </p>
  </div>

  <!-- Matchday accordions -->
  <div class="border-t border-[var(--border)]">
    {jornadas.map(({ label, matches, xg }) => {
      const hasAnyReal = matches.some((m: MatchResult) => lookupReal(m) !== undefined);
      return (
        <details class="border-b border-[var(--border)] last:border-0" open={hasAnyReal}>
          <summary class="flex items-center justify-between px-4 py-2 cursor-pointer text-xs font-semibold text-[var(--text-muted)] hover:text-[var(--text-base)] select-none list-none">
            <span>{label}</span>
            {hasAnyReal && (
              <span class="text-[9px] font-bold px-1 rounded bg-[var(--green)]/20 text-[var(--green)] mr-auto ml-2">JUGADO</span>
            )}
            <svg class="w-3 h-3 transition-transform" viewBox="0 0 12 12" fill="none" stroke="currentColor">
              <path d="M2 4l4 4 4-4" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </summary>
          <div class="px-3 pb-3 space-y-1 pt-1">
            {matches.map((m: MatchResult) => {
              const real = lookupReal(m);
              return (
                <MatchCard
                  team1={m.team1} score1={m.score1}
                  team2={m.team2} score2={m.score2}
                  xg1={lookupXG(xg, m.team1)}
                  xg2={lookupXG(xg, m.team2)}
                  realScore1={real?.r1}
                  realScore2={real?.r2}
                />
              );
            })}
          </div>
        </details>
      );
    })}
  </div>
</div>
